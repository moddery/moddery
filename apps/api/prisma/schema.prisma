generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountRole {
  USER
  MODERATOR
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum AuthProvider {
  DISCORD
  GITHUB
  GOOGLE
}

enum CollectionVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum DependencyKind {
  REQUIRED
  OPTIONAL
  INCOMPATIBLE
  EMBEDDED
}

enum FileKind {
  UNIVERSAL
  CLIENT
  SERVER
}

enum FriendState {
  PENDING
  ACCEPTED
  BLOCKED
}

enum HashAlgorithm {
  SHA1
  SHA256
  SHA512
}

enum LinkKind {
  SOURCE
  ISSUES
  WIKI
  DISCORD
  DONATION
  WEBSITE
  OTHER
}

enum Loader {
  FABRIC
  FORGE
  NEOFORGE
  QUILT
}

enum ModerationActionKind {
  APPROVE
  REJECT
  REQUEST_CHANGES
  ARCHIVE
  RESTORE
  LOCK
  UNLOCK
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationState {
  PENDING
  SENT
  READ
  FAILED
}

enum OAuthClientStatus {
  ACTIVE
  REVOKED
}

enum ProjectKind {
  MOD
  MODPACK
  RESOURCE_PACK
  SHADER
  PLUGIN
  DATAPACK
}

enum ProjectStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum ReportReason {
  SPAM
  MALWARE
  COPYRIGHT
  IMPERSONATION
  HATEFUL_OR_ABUSIVE
  BROKEN_OR_MISLEADING
  OTHER
}

enum ReportState {
  OPEN
  TRIAGED
  CLOSED
}

enum TeamPermission {
  MANAGE_DETAILS
  MANAGE_VERSIONS
  MANAGE_MEMBERS
  MANAGE_SETTINGS
  VIEW_ANALYTICS
}

enum TeamTargetKind {
  PROJECT
  ORGANIZATION
}

enum VersionChannel {
  ALPHA
  BETA
  RELEASE
}

enum VersionStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

model User {
  id                      String                   @id @default(cuid())
  username                String                   @unique
  displayName             String?
  email                   String?                  @unique
  emailVerifiedAt         DateTime?
  bio                     String?
  avatarUrl               String?
  friendRequestsReceived  Friend[]                 @relation("FriendAddressee")
  friendRequestsSent      Friend[]                 @relation("FriendRequester")
  role                    AccountRole              @default(USER)
  status                  AccountStatus            @default(ACTIVE)
  twoFactorEnabled        Boolean                  @default(false)
  newsletterOptIn         Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  authAccounts            UserAuthAccount[]
  apiTokens               ApiToken[]
  collections             Collection[]
  collectionItemsAdded    CollectionProject[]
  moderationActions       ModerationAction[]
  moderationLocks         ModerationLock[]
  moderationNotesAuthored ModerationNote[]         @relation("ModerationNotesAuthored")
  moderationNotesReceived ModerationNote[]         @relation("ModerationNotesReceived")
  notificationPreferences NotificationPreference[]
  notifications           Notification[]
  oauthClients            OAuthClient[]
  ownedOrganizations      Organization[]
  projectFollows          ProjectFollow[]
  projectViews            ProjectViewEvent[]
  reportsFiled            Report[]                 @relation("ReportsFiled")
  reportsReceived         Report[]                 @relation("ReportsReceived")
  sessions                Session[]
  teamMemberships         TeamMember[]
  threadMessages          ThreadMessage[]
  threadMemberships       ThreadMember[]
  uploadedVersions        Version[]
  passwordCredential      PasswordCredential?
  passwordResetTokens     PasswordResetToken[]
  auditLogsAuthored       AuditLog[]               @relation("AuditLogActor")
  auditLogsTargetingUser  AuditLog[]               @relation("AuditLogTargetUser")

  @@index([role])
  @@index([status])
  @@map("users")
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  targetUserId String?
  action       String
  metadata     Json?
  createdAt    DateTime @default(now())
  actor        User?    @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetUser   User?    @relation("AuditLogTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([targetUserId, createdAt])
  @@map("audit_logs")
}

model Friend {
  id          String      @id @default(cuid())
  requesterId String
  addresseeId String
  state       FriendState @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  acceptedAt  DateTime?
  requester   User        @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User        @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, state])
  @@index([requesterId, state])
  @@map("friends")
}

model PasswordCredential {
  userId            String   @id
  passwordHash      String
  passwordChangedAt DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_credentials")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model UserAuthAccount {
  id         String       @id @default(cuid())
  userId     String
  provider   AuthProvider
  providerId String
  createdAt  DateTime     @default(now())
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("user_auth_accounts")
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  userAgent  String?
  ipHash     String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  name       String
  tokenHash  String    @unique
  scopes     String[]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_tokens")
}

model OAuthClient {
  id               String                   @id @default(cuid())
  ownerId          String
  clientId         String                   @unique
  clientSecretHash String
  name             String
  description      String?
  homepageUrl      String?
  status           OAuthClientStatus        @default(ACTIVE)
  scopes           String[]                 @default([])
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  revokedAt        DateTime?
  owner            User                     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  redirectUris     OAuthClientRedirectUri[]

  @@index([ownerId, status])
  @@map("oauth_clients")
}

model OAuthClientRedirectUri {
  id        String      @id @default(cuid())
  clientId  String
  uri       String
  createdAt DateTime    @default(now())
  client    OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, uri])
  @@map("oauth_client_redirect_uris")
}

model Team {
  id           String         @id @default(cuid())
  targetKind   TeamTargetKind
  createdAt    DateTime       @default(now())
  members      TeamMember[]
  organization Organization?
  project      Project?

  @@index([targetKind])
  @@map("teams")
}

model TeamMember {
  id          String           @id @default(cuid())
  teamId      String
  userId      String
  role        String
  permissions TeamPermission[]
  isOwner     Boolean          @default(false)
  acceptedAt  DateTime?
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  team        Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model Organization {
  id          String    @id @default(cuid())
  teamId      String    @unique
  ownerId     String
  slug        String    @unique
  name        String
  description String?
  iconUrl     String?
  color       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  projects    Project[]
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Restrict)

  @@index([ownerId])
  @@map("organizations")
}

model Project {
  id                 String                @id @default(cuid())
  teamId             String                @unique
  organizationId     String?
  slug               String                @unique
  title              String
  summary            String
  description        String
  kind               ProjectKind
  status             ProjectStatus         @default(DRAFT)
  requestedStatus    ProjectStatus?
  licenseId          String?
  iconUrl            String?
  color              String?
  sourceUrl          String?
  issuesUrl          String?
  wikiUrl            String?
  discordUrl         String?
  downloads          Int                   @default(0)
  followers          Int                   @default(0)
  publishedAt        DateTime?
  approvedAt         DateTime?
  queuedAt           DateTime?
  archivedAt         DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  categories         ProjectCategory[]
  dependencies       VersionDependency[]   @relation("DependencyProject")
  downloadEvents     DownloadEvent[]
  follows            ProjectFollow[]
  gallery            ProjectGalleryImage[]
  gameVersions       ProjectGameVersion[]
  links              ProjectLink[]
  license            License?              @relation(fields: [licenseId], references: [id], onDelete: SetNull)
  loaders            ProjectLoader[]
  moderationActions  ModerationAction[]
  moderationLock     ModerationLock?
  organization       Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  projectCollections CollectionProject[]
  reports            Report[]
  moderationNotes    ModerationNote[]
  team               Team                  @relation(fields: [teamId], references: [id], onDelete: Restrict)
  versions           Version[]
  viewEvents         ProjectViewEvent[]

  @@index([kind])
  @@index([organizationId])
  @@index([status])
  @@index([updatedAt])
  @@map("projects")
}

model License {
  id        String    @id @default(cuid())
  key       String    @unique
  name      String
  url       String?
  createdAt DateTime  @default(now())
  projects  Project[]

  @@map("licenses")
}

model Category {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  description String?
  projectKind ProjectKind?
  createdAt   DateTime          @default(now())
  projects    ProjectCategory[]

  @@index([projectKind])
  @@map("categories")
}

model ProjectCategory {
  projectId  String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, categoryId])
  @@index([categoryId])
  @@map("project_categories")
}

model GameVersion {
  id         String               @id @default(cuid())
  version    String               @unique
  releasedAt DateTime?
  isActive   Boolean              @default(true)
  projects   ProjectGameVersion[]
  versions   VersionGameVersion[]

  @@index([isActive])
  @@map("game_versions")
}

model ProjectGameVersion {
  projectId     String
  gameVersionId String
  gameVersion   GameVersion @relation(fields: [gameVersionId], references: [id], onDelete: Cascade)
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, gameVersionId])
  @@index([gameVersionId])
  @@map("project_game_versions")
}

model ProjectLoader {
  projectId String
  loader    Loader
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, loader])
  @@map("project_loaders")
}

model Version {
  id              String               @id @default(cuid())
  projectId       String
  authorId        String?
  versionNumber   String
  name            String
  changelog       String?
  channel         VersionChannel       @default(RELEASE)
  status          VersionStatus        @default(DRAFT)
  requestedStatus VersionStatus?
  downloads       Int                  @default(0)
  featured        Boolean              @default(false)
  sortOrder       Int                  @default(0)
  publishedAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  author          User?                @relation(fields: [authorId], references: [id], onDelete: SetNull)
  dependencyOf    VersionDependency[]  @relation("DependencyVersion")
  dependencies    VersionDependency[]  @relation("VersionDependencies")
  downloadEvents  DownloadEvent[]
  files           VersionFile[]
  gameVersions    VersionGameVersion[]
  loaders         VersionLoader[]
  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reports         Report[]

  @@unique([projectId, versionNumber])
  @@index([authorId])
  @@index([projectId, status])
  @@index([publishedAt])
  @@map("versions")
}

model VersionGameVersion {
  versionId     String
  gameVersionId String
  gameVersion   GameVersion @relation(fields: [gameVersionId], references: [id], onDelete: Cascade)
  version       Version     @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@id([versionId, gameVersionId])
  @@index([gameVersionId])
  @@map("version_game_versions")
}

model VersionLoader {
  versionId String
  loader    Loader
  version   Version @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@id([versionId, loader])
  @@map("version_loaders")
}

model VersionFile {
  id        String     @id @default(cuid())
  versionId String
  bucket    String
  key       String
  url       String
  fileName  String
  kind      FileKind   @default(UNIVERSAL)
  isPrimary Boolean    @default(false)
  sizeBytes BigInt
  createdAt DateTime   @default(now())
  hashes    FileHash[]
  scans     FileScan[]
  version   Version    @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([bucket, key])
  @@index([versionId])
  @@map("version_files")
}

model FileHash {
  fileId    String
  algorithm HashAlgorithm
  value     String
  file      VersionFile   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@id([fileId, algorithm])
  @@index([algorithm, value])
  @@map("file_hashes")
}

model VersionDependency {
  id               String         @id @default(cuid())
  versionId        String
  dependencyKind   DependencyKind
  targetProjectId  String?
  targetVersionId  String?
  externalFileName String?
  targetProject    Project?       @relation("DependencyProject", fields: [targetProjectId], references: [id], onDelete: SetNull)
  targetVersion    Version?       @relation("DependencyVersion", fields: [targetVersionId], references: [id], onDelete: SetNull)
  version          Version        @relation("VersionDependencies", fields: [versionId], references: [id], onDelete: Cascade)

  @@index([targetProjectId])
  @@index([targetVersionId])
  @@index([versionId])
  @@map("version_dependencies")
}

model ProjectGalleryImage {
  id          String   @id @default(cuid())
  projectId   String
  rawUrl      String
  displayUrl  String
  title       String?
  description String?
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
  @@map("project_gallery_images")
}

model ProjectLink {
  id        String   @id @default(cuid())
  projectId String
  kind      LinkKind
  label     String?
  url       String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_links")
}

model ProjectFollow {
  userId    String
  projectId String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
  @@index([projectId])
  @@map("project_follows")
}

model Collection {
  id          String               @id @default(cuid())
  ownerId     String
  slug        String
  name        String
  description String?
  visibility  CollectionVisibility @default(PRIVATE)
  iconUrl     String?
  color       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  owner       User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  projects    CollectionProject[]

  @@unique([ownerId, slug])
  @@index([visibility])
  @@map("collections")
}

model CollectionProject {
  collectionId String
  projectId    String
  addedById    String?
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  addedBy      User?      @relation(fields: [addedById], references: [id], onDelete: SetNull)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([collectionId, projectId])
  @@index([projectId])
  @@map("collection_projects")
}

model Report {
  id           String       @id @default(cuid())
  reporterId   String
  projectId    String?
  versionId    String?
  userTargetId String?
  reason       ReportReason
  body         String
  state        ReportState  @default(OPEN)
  createdAt    DateTime     @default(now())
  closedAt     DateTime?
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reporter     User         @relation("ReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  thread       Thread?
  userTarget   User?        @relation("ReportsReceived", fields: [userTargetId], references: [id], onDelete: Cascade)
  version      Version?     @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([reporterId])
  @@index([state])
  @@index([versionId])
  @@map("reports")
}

model Thread {
  id        String          @id @default(cuid())
  reportId  String?         @unique
  subject   String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  members   ThreadMember[]
  messages  ThreadMessage[]
  report    Report?         @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
  @@map("threads")
}

model ThreadMember {
  threadId   String
  userId     String
  lastReadAt DateTime?
  createdAt  DateTime @default(now())
  thread     Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([threadId, userId])
  @@index([userId])
  @@map("thread_members")
}

model ThreadMessage {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([threadId, createdAt])
  @@map("thread_messages")
}

model ModerationAction {
  id          String               @id @default(cuid())
  moderatorId String
  projectId   String?
  kind        ModerationActionKind
  reason      String?
  metadata    Json?
  createdAt   DateTime             @default(now())
  moderator   User                 @relation(fields: [moderatorId], references: [id], onDelete: Restrict)
  project     Project?             @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([moderatorId])
  @@index([projectId])
  @@map("moderation_actions")
}

model ModerationLock {
  id          String   @id @default(cuid())
  moderatorId String
  projectId   String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  moderator   User     @relation(fields: [moderatorId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([moderatorId])
  @@index([expiresAt])
  @@map("moderation_locks")
}

model ModerationNote {
  id        String   @id @default(cuid())
  authorId  String
  userId    String?
  projectId String?
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation("ModerationNotesAuthored", fields: [authorId], references: [id], onDelete: Restrict)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User?    @relation("ModerationNotesReceived", fields: [userId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([projectId])
  @@index([userId])
  @@map("moderation_notes")
}

model FileScan {
  id        String      @id @default(cuid())
  fileId    String
  status    String
  verdict   String?
  details   Json?
  createdAt DateTime    @default(now())
  file      VersionFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@map("file_scans")
}

model Notification {
  id         String                 @id @default(cuid())
  userId     String
  type       String
  title      String
  body       String?
  actionUrl  String?
  state      NotificationState      @default(PENDING)
  createdAt  DateTime               @default(now())
  readAt     DateTime?
  deliveries NotificationDelivery[]
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([state])
  @@index([userId, createdAt])
  @@map("notifications")
}

model NotificationDelivery {
  id             String              @id @default(cuid())
  notificationId String
  channel        NotificationChannel
  state          NotificationState   @default(PENDING)
  attempts       Int                 @default(0)
  lastError      String?
  scheduledAt    DateTime            @default(now())
  sentAt         DateTime?
  notification   Notification        @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([channel, state])
  @@index([notificationId])
  @@map("notification_deliveries")
}

model NotificationPreference {
  userId    String
  type      String
  channel   NotificationChannel
  enabled   Boolean             @default(true)
  updatedAt DateTime            @updatedAt
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, type, channel])
  @@map("notification_preferences")
}

model ProjectViewEvent {
  id          String   @id @default(cuid())
  projectId   String
  userId      String?
  countryCode String?
  userAgent   String?
  referrer    String?
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([projectId, createdAt])
  @@map("project_view_events")
}

model DownloadEvent {
  id          String   @id @default(cuid())
  projectId   String
  versionId   String?
  countryCode String?
  userAgent   String?
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version     Version? @relation(fields: [versionId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([projectId, createdAt])
  @@index([versionId])
  @@map("download_events")
}
