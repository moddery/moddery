NODE_ENV=production
PORT=3000
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_TTL_SECONDS=60
REQUEST_LOGGING_ENABLED=true
SECURITY_HEADERS_ENABLED=true
TRUST_PROXY_HOPS=1

# Public URLs and hosts. Use hostnames without schemes for Caddy hosts.
PUBLIC_WEB_URL=https://moddery.example.com
PUBLIC_API_URL=https://api.moddery.example.com
PUBLIC_STORAGE_URL=https://files.moddery.example.com
PUBLIC_WEB_HOST=moddery.example.com
PUBLIC_API_HOST=api.moddery.example.com
PUBLIC_STORAGE_HOST=files.moddery.example.com
ACME_EMAIL=ops@example.com
CORS_ORIGINS=https://moddery.example.com
VITE_GRAPHQL_URL=https://api.moddery.example.com/graphql

# Application secrets.
JWT_ACCESS_TOKEN_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_TOKEN_TTL_SECONDS=900

# Postgres is internal to docker-compose.prod.yml.
POSTGRES_DB=moddery
POSTGRES_USER=moddery
POSTGRES_PASSWORD=replace-with-a-random-database-password
DATABASE_URL=postgresql://moddery:replace-with-a-random-database-password@postgres:5432/moddery?schema=public

# Redis is internal to docker-compose.prod.yml.
REDIS_URL=redis://redis:6379

# Email.
MAIL_FROM=noreply@moddery.example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587

# OpenSearch is internal to docker-compose.prod.yml.
OPENSEARCH_NODE=http://opensearch:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# ClickHouse is internal to docker-compose.prod.yml.
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=moddery

# ClamAV is internal to docker-compose.prod.yml.
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# MinIO is internal to docker-compose.prod.yml and exposed through Caddy.
MINIO_ROOT_USER=moddery-minio
MINIO_ROOT_PASSWORD=replace-with-a-random-minio-password
S3_ENDPOINT=http://minio:9000
S3_PRESIGN_ENDPOINT=https://files.moddery.example.com
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=moddery-minio
S3_SECRET_ACCESS_KEY=replace-with-a-random-minio-password
S3_BUCKET=moddery-prod
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=https://files.moddery.example.com/moddery-prod
