{
  "name": "moddery",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.1.42",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter './packages/*' build && bun run --filter './apps/*' build",
    "check": "bun run typecheck && bun run lint && bun run format:check",
    "dev": "bun run dev:api",
    "dev:api": "bun run --filter @moddery/api start:dev",
    "dev:web": "bun run --filter @moddery/web dev",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:dev:detached": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "bun run --filter './packages/*' test && bun run --filter './apps/*' test",
    "typecheck": "bun run --filter './packages/*' typecheck && bun run --filter './apps/*' typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/bun": "^1.2.17",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import-x": "^4.15.2",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1"
  }
}
